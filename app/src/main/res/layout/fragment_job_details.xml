<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_gray"
    android:layoutDirection="rtl">

    <RelativeLayout
        android:id="@+id/headerBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:background="@color/white"
        android:elevation="2dp"
        android:layout_alignParentTop="true">

        <ImageButton
            android:id="@+id/btnBackJobDetails"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_revert"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:contentDescription="Back" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="פרטי המשרה"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/brand_purple"
            android:layout_centerInParent="true" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/headerBar"
        android:layout_above="@id/bottomBar"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/tvDetailTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="כותרת משרה"
                android:textColor="@color/brand_purple"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvDetailCompany"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="שם העסק"
                android:textColor="#424242"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/tvDetailLocation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="עיר - כתובת מדויקת"
                android:textColor="#757575"
                android:textSize="16sp"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/tvDetailBusinessDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="תיאור העסק..."
                android:textColor="#616161"
                android:textSize="15sp"
                android:layout_marginTop="8dp"
                android:lineSpacingExtra="2dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="על המשרה"
                android:textColor="@color/black"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvDetailDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="תיאור המשרה כאן..."
                android:textColor="#424242"
                android:textSize="16sp"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="20dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="דרישות ומאפיינים"
                android:textColor="@color/black"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvDetailWorkField"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="תחום עבודה: "
                android:textColor="#424242"
                android:textSize="16sp"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/tvDetailScope"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="היקף משרה: "
                android:textColor="#424242"
                android:textSize="16sp"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/tvDetailAge"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="גיל מינימלי: "
                android:textColor="#424242"
                android:textSize="16sp"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/tvDetailExperience"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ניסיון דרוש: "
                android:textColor="#424242"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="24dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="שכר"
                android:textColor="@color/black"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvDetailSalary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="שכר: 45 ₪ / שעה"
                android:textColor="#1A237E"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="30dp" />

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="@color/white"
        android:elevation="10dp"
        android:padding="16dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvDetailContactName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="איש קשר: "
            android:textSize="14sp"
            android:textColor="#424242"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnContact"
                android:layout_width="0dp"
                android:layout_height="55dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="חייג"
                android:textSize="16sp"
                app:backgroundTint="#1A237E"
                app:cornerRadius="25dp"
                app:icon="@android:drawable/ic_menu_call"
                app:iconGravity="textStart"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnApplySMS"
                android:layout_width="0dp"
                android:layout_height="55dp"
                android:layout_weight="2"
                android:text="הגש מועמדות (SMS)"
                android:textSize="15sp"
                app:backgroundTint="#0288D1"
                app:cornerRadius="25dp"
                app:icon="@android:drawable/ic_menu_send"
                app:iconGravity="textStart"
                android:visibility="gone"/>
        </LinearLayout>
    </LinearLayout>
</RelativeLayout>